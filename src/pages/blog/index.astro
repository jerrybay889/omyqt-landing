---
import Base from '../../layouts/Base.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function formatDate(date: Date): string {
  return date.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Base title="블로그 — OMYQT" description="매일 묵상, AI 성경 해석, QT 가이드 등 OMYQT의 이야기를 읽어보세요.">
  <!-- Navigation -->
  <header class="sticky top-0 z-50 border-b border-border bg-background/95 backdrop-blur">
    <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3">
      <a href="/" class="font-display text-base font-bold text-foreground">OMYQT</a>
      <nav class="flex gap-4 text-sm text-muted-foreground">
        <a href="/blog" class="font-medium text-foreground">블로그</a>
        <a href="/#features" class="hover:text-foreground transition-colors">기능</a>
      </nav>
    </div>
  </header>

  <main class="mx-auto max-w-5xl px-4 py-16">
    <div class="mb-12">
      <h1 class="font-display text-4xl font-bold text-foreground">블로그</h1>
      <p class="mt-3 text-lg text-muted-foreground">
        매일 묵상, 성경 QT 가이드, OMYQT 소식을 전합니다.
      </p>
    </div>

    {posts.length === 0 ? (
      <p class="text-muted-foreground">아직 게시글이 없습니다.</p>
    ) : (
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="group rounded-2xl border border-border bg-white p-6 transition-all hover:border-accent/30 hover:shadow-lg"
          >
            {post.data.image && (
              <div class="mb-4 aspect-video overflow-hidden rounded-xl bg-muted">
                <img src={post.data.image} alt={post.data.title} class="h-full w-full object-cover" loading="lazy" />
              </div>
            )}
            <div class="flex flex-wrap gap-2 mb-3">
              {post.data.tags.slice(0, 3).map((tag) => (
                <span class="rounded-full bg-accent/10 px-2.5 py-0.5 text-xs font-medium text-accent-foreground">
                  {tag}
                </span>
              ))}
            </div>
            <h2 class="text-lg font-bold text-foreground group-hover:text-primary transition-colors">
              {post.data.title}
            </h2>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground line-clamp-2">
              {post.data.description}
            </p>
            <time datetime={post.data.date.toISOString()} class="mt-3 block text-xs text-muted-foreground">
              {formatDate(post.data.date)}
            </time>
          </a>
        ))}
      </div>
    )}
  </main>

  <Footer />
</Base>
