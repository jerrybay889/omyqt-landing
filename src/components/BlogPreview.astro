---
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const recentPosts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

function formatDate(date: Date): string {
  return date.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

{recentPosts.length > 0 && (
  <section class="bg-muted px-4 py-20 md:py-28">
    <div class="mx-auto max-w-5xl">
      <div class="flex items-end justify-between">
        <div>
          <span class="text-sm font-medium uppercase tracking-widest text-accent">Blog</span>
          <h2 class="mt-3 font-display text-3xl font-bold text-foreground md:text-4xl">
            묵상 이야기
          </h2>
        </div>
        <a href="/blog" class="hidden text-sm font-medium text-primary hover:text-accent transition-colors sm:block">
          모든 글 보기 &rarr;
        </a>
      </div>

      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {recentPosts.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="group rounded-2xl border border-border bg-white p-6 transition-all hover:border-accent/30 hover:shadow-lg"
          >
            {post.data.image && (
              <div class="mb-4 aspect-video overflow-hidden rounded-xl bg-muted">
                <img src={post.data.image} alt={post.data.title} class="h-full w-full object-cover" />
              </div>
            )}
            <div class="flex flex-wrap gap-2 mb-3">
              {post.data.tags.slice(0, 2).map((tag) => (
                <span class="rounded-full bg-accent/10 px-2.5 py-0.5 text-xs font-medium text-accent-foreground">
                  {tag}
                </span>
              ))}
            </div>
            <h3 class="text-lg font-bold text-foreground group-hover:text-primary transition-colors">
              {post.data.title}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground line-clamp-2">
              {post.data.description}
            </p>
            <p class="mt-3 text-xs text-muted-foreground">
              {formatDate(post.data.date)}
            </p>
          </a>
        ))}
      </div>

      <div class="mt-8 text-center sm:hidden">
        <a href="/blog" class="text-sm font-medium text-primary hover:text-accent transition-colors">
          모든 글 보기 &rarr;
        </a>
      </div>
    </div>
  </section>
)}
