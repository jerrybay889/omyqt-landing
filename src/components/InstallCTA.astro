---
import { site } from '../content/site';
---

<section class="px-4 py-20 md:py-28">
  <div class="mx-auto max-w-3xl text-center">
    <h2 class="font-display text-3xl font-bold text-foreground md:text-4xl">
      오늘부터 시작하세요
    </h2>
    <p class="mx-auto mt-4 max-w-lg text-base text-muted-foreground">
      매일 아침, 당신만을 위한 말씀이 준비됩니다. 무료로 시작하세요.
    </p>

    <!-- CTA buttons -->
    <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
      <a
        href={site.appAuthUrl}
        class="inline-flex items-center gap-2 rounded-xl bg-accent px-8 py-4 text-base font-bold text-accent-foreground shadow-lg transition-all hover:brightness-110"
      >
        지금 무료로 시작하기
      </a>
    </div>

    <!-- 앱 출시 안내 -->
    <div class="mx-auto mt-10 max-w-lg rounded-2xl border border-border bg-muted/50 px-6 py-5 text-left">
      <p class="mb-3 text-sm font-semibold text-foreground">📱 앱 출시 안내</p>
      <ul class="space-y-2 text-sm text-muted-foreground">
        <li class="flex items-start gap-2">
          <span class="mt-0.5 text-green-500">●</span>
          <span><strong class="text-foreground">지금 바로 이용 가능</strong> — 모바일 웹 브라우저로 즐기실 수 있습니다.</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="mt-0.5 text-yellow-500">●</span>
          <span><strong class="text-foreground">Google Play</strong> — 조만간 출시 예정입니다.</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="mt-0.5 text-orange-400">●</span>
          <span><strong class="text-foreground">App Store (iPhone)</strong> — 좀 더 시일이 걸릴 예정입니다.</span>
        </li>
      </ul>
    </div>

    <!-- 홈 화면 추가 가이드 -->
    <div class="mx-auto mt-6 max-w-lg rounded-2xl border border-accent/30 bg-accent/5 px-6 py-6 text-left">
      <p class="mb-1 text-sm font-semibold text-foreground">💡 앱처럼 편리하게 쓰는 방법</p>
      <p class="mb-4 text-xs text-muted-foreground">홈 화면에 추가하면 매일 아침 아이콘 한 번으로 바로 열 수 있어요.</p>

      <div class="space-y-4">
        <!-- 안드로이드 -->
        <div>
          <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-muted-foreground">🤖 안드로이드 (크롬 브라우저)</p>
          <ol class="space-y-1.5 text-sm text-foreground">
            <li class="flex gap-2"><span class="shrink-0 font-bold text-accent">1.</span><span>Chrome에서 <strong>app.omyqt.com</strong> 접속</span></li>
            <li class="flex gap-2"><span class="shrink-0 font-bold text-accent">2.</span><span>오른쪽 위 <strong>⋮ (점 세 개)</strong> 버튼 탭</span></li>
            <li class="flex gap-2"><span class="shrink-0 font-bold text-accent">3.</span><span><strong>"홈 화면에 추가"</strong> 선택 → 추가 완료</span></li>
          </ol>
        </div>

        <div class="border-t border-border/40"></div>

        <!-- 아이폰 -->
        <div>
          <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-muted-foreground">🍎 아이폰 (사파리 브라우저)</p>
          <ol class="space-y-1.5 text-sm text-foreground">
            <li class="flex gap-2"><span class="shrink-0 font-bold text-accent">1.</span><span>Safari에서 <strong>app.omyqt.com</strong> 접속</span></li>
            <li class="flex gap-2"><span class="shrink-0 font-bold text-accent">2.</span><span>하단 가운데 <strong>공유 버튼 (□↑)</strong> 탭</span></li>
            <li class="flex gap-2"><span class="shrink-0 font-bold text-accent">3.</span><span><strong>"홈 화면에 추가"</strong> 선택 → 추가 완료</span></li>
          </ol>
        </div>
      </div>

      <p class="mt-4 text-xs text-muted-foreground">
        홈 화면에 추가 후 매일 아침 OMYQT 아이콘을 탭하면 바로 오늘의 말씀이 열립니다.
      </p>
    </div>

    <!-- Waitlist email -->
    <div class="mx-auto mt-10 max-w-md">
      <p class="mb-4 text-sm text-muted-foreground">
        Google Play · App Store 출시 알림 받기
      </p>
      <form id="waitlist-form" class="flex gap-2">
        <input
          type="email"
          id="waitlist-email"
          placeholder="이메일을 입력하세요"
          required
          class="flex-1 rounded-xl border border-border bg-white px-4 py-3 text-sm outline-none transition-all focus:border-accent focus:ring-2 focus:ring-accent/20"
        />
        <button
          type="submit"
          class="rounded-xl bg-primary px-6 py-3 text-sm font-bold text-primary-foreground transition-all hover:brightness-110"
        >
          알림 받기
        </button>
      </form>
      <p id="waitlist-message" class="mt-2 hidden text-sm font-medium text-accent"></p>
    </div>
  </div>
</section>

<script define:vars={{ supabaseUrl: site.supabaseUrl, supabaseAnonKey: site.supabaseAnonKey }}>
  const form = document.getElementById('waitlist-form');
  const msg = document.getElementById('waitlist-message');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = document.getElementById('waitlist-email').value;

    try {
      const res = await fetch(`${supabaseUrl}/rest/v1/waiting_list`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'apikey': supabaseAnonKey,
          'Prefer': 'return=minimal',
        },
        body: JSON.stringify({ email }),
      });

      if (res.ok || res.status === 201) {
        form.classList.add('hidden');
        msg.textContent = '등록 완료! 출시 소식을 알려드릴게요 ✉️';
        msg.classList.remove('hidden');
      } else if (res.status === 409) {
        msg.textContent = '이미 등록된 이메일입니다.';
        msg.classList.remove('hidden');
      } else {
        throw new Error('failed');
      }
    } catch {
      msg.textContent = '오류가 발생했습니다. 잠시 후 다시 시도해주세요.';
      msg.classList.remove('hidden');
    }
  });
</script>
