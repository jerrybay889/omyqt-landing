---
import { site } from '../content/site';
---

<section id="features" class="px-4 py-20 md:py-28">
  <div class="mx-auto max-w-5xl">
    <!-- Section header -->
    <div class="text-center">
      <span class="text-sm font-medium uppercase tracking-widest text-accent">Features</span>
      <h2 class="mt-3 font-display text-3xl font-bold text-foreground md:text-4xl">
        당신의 묵상을 더 깊이 있게
      </h2>
      <p class="mx-auto mt-4 max-w-lg text-base text-muted-foreground">
        OMYQT는 단순한 성경 읽기 앱이 아닙니다. AI가 당신의 삶에 말씀을 연결해 드립니다.
      </p>
    </div>

    <!-- Feature grid -->
    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {site.features.map((feature) => (
        <div class="group rounded-2xl border border-border bg-white p-6 transition-all hover:border-accent/30 hover:shadow-lg">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-muted text-2xl">
            {feature.icon}
          </div>
          <h3 class="text-lg font-bold text-foreground">{feature.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
