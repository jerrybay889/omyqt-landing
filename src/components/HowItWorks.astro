---
import { site } from '../content/site';
---

<section class="bg-muted px-4 py-20 md:py-28">
  <div class="mx-auto max-w-5xl">
    <div class="text-center">
      <span class="text-sm font-medium uppercase tracking-widest text-accent">How It Works</span>
      <h2 class="mt-3 font-display text-3xl font-bold text-foreground md:text-4xl">
        3단계로 시작하세요
      </h2>
    </div>

    <div class="mt-16 grid gap-8 md:grid-cols-3">
      {site.steps.map((step, i) => (
        <div class="relative text-center">
          {/* Connector line (desktop) */}
          {i < site.steps.length - 1 && (
            <div class="absolute right-0 top-8 hidden h-0.5 w-full translate-x-1/2 bg-border md:block"></div>
          )}

          <div class="relative mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-primary text-xl font-bold text-primary-foreground shadow-lg">
            {step.step}
          </div>
          <h3 class="text-xl font-bold text-foreground">{step.title}</h3>
          <p class="mt-3 whitespace-pre-line text-sm leading-relaxed text-muted-foreground">
            {step.description}
          </p>
        </div>
      ))}
    </div>

    <div class="mt-14 text-center">
      <a
        href={site.appUrl}
        class="inline-flex items-center gap-2 rounded-xl bg-accent px-8 py-4 text-base font-bold text-accent-foreground shadow-lg transition-all hover:brightness-110"
      >
        지금 시작하기
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </div>
</section>
