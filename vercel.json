{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "omyqt.com" }],
      "destination": "https://www.omyqt.com/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    }
  ]
}
